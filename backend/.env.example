NODE_ENV=development
PORT=3003

# Public URLs (production example)
# FRONTEND_URL=https://vixxy-dorance.vercel.app
# BACKEND_URL=https://vixxy-dorance-api.onrender.com
# ADMIN_URL=https://vixxy-dorance-admin.vercel.app
# CORS_ORIGINS=https://vixxy-dorance.vercel.app,https://vixxy-dorance-admin.vercel.app

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3003
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Database
# Local development (Sequelize uses DB_STORAGE; Prisma auth uses DATABASE_URL below)
DB_STORAGE=./database.sqlite
DATABASE_URL="file:./database.sqlite"

# Production (Supabase PostgreSQL - set on Render)
# Change prisma/schema.prisma provider to "postgresql" before deploying.
# Direct connection (port 5432):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require
# Connection pooler (recommended for production, port 6543):
# DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Do NOT use file:./database.sqlite in production — use a PostgreSQL connection string instead.

# Seed demo data on first deploy (set true on Render, then false after first successful deploy)
SEED_ON_START=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI (optional - free tier)
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Cloudinary (optional - free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ZaloPay Sandbox (demo)
ZALOPAY_APP_ID=2553
ZALOPAY_KEY1=PcY4iZIKFCIdgZvA6ueMcMHHUbRLYjPL
ZALOPAY_KEY2=kLtgPl8HHhfvMuDHPwKfgfsY4Ydm9eIz

