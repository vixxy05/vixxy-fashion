{
  "name": "vixxy-backend",
  "version": "1.0.0",
  "description": "Backend API for VIXXY D'ORANCE",
  "main": "src/server.ts",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:prod": "prisma generate",
    "postinstall": "prisma generate",
    "start": "node dist/server.js",
    "start:prod": "prisma db push && tsx src/server.ts",
    "seed": "prisma db seed",
    "seed:sequelize": "tsx src/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "test": "cross-env NODE_ENV=test jest --config jest.config.js",
    "test:unit": "cross-env NODE_ENV=test jest --config jest.config.js --testPathPatterns=unit",
    "test:integration": "cross-env NODE_ENV=test jest --config jest.config.js --testPathPatterns=integration",
    "test:auth": "cross-env NODE_ENV=test jest --config jest.config.js --testPathPatterns=auth",
    "test:coverage": "cross-env NODE_ENV=test jest --config jest.config.js --coverage"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.18.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mysql2": "^3.11.4",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.1",
    "xss": "^1.0.15",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/moment": "^2.11.29",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
